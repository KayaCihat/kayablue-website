---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found">
  <section class="container not-found">
    <h1 class="not-found__code">404</h1>
    <p class="not-found__msg">Page not found.</p>
    <a href="/" class="not-found__link">Back to home →</a>
  </section>
</BaseLayout>

<style>
  .not-found {
    padding-top: 6rem;
    text-align: center;
  }
  .not-found__code {
    font-size: 6rem;
    font-weight: 800;
    opacity: 0.15;
    line-height: 1;
  }
  .not-found__msg {
    font-size: 1.25rem;
    margin: 1.5rem 0 2rem;
  }
  .not-found__link {
    color: var(--color-accent);
    font-weight: 600;
  }
</style>
