---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Careers" description="Join Kayablue — architects of high-performance digital experiences">

  <!-- Hero -->
  <section class="careers-hero">
    <div class="container">
      <h1 class="careers-hero__heading">Join the Architects of the Digital Frontier</h1>
      <p class="careers-hero__desc">We're building the structural backbone of tomorrow's web with high-performance logic and architectural precision. We don't just build sites — we build revenue engines.</p>
    </div>
  </section>

  <!-- Open Positions -->
  <section class="positions">
    <div class="container">
      <h2 class="section-title">Open Positions</h2>
      <div class="positions__list">

        <div class="job-card">
          <div class="job-card__meta">
            <span class="job-card__dept job-card__dept--engineering">Engineering</span>
            <span class="job-card__tags">
              <span class="tag">REMOTE</span>
              <span class="tag">FULL-TIME</span>
            </span>
          </div>
          <h3 class="job-card__title">Senior Systems Architect</h3>
          <p class="job-card__desc">Design and scale distributed infrastructure for global architectural platforms. Lead the technical direction of our most ambitious client engagements.</p>
          <a href="/book-a-call" class="btn btn--ghost">Apply Now</a>
        </div>

        <div class="job-card">
          <div class="job-card__meta">
            <span class="job-card__dept job-card__dept--design">Design</span>
            <span class="job-card__tags">
              <span class="tag">LONDON</span>
              <span class="tag">HYBRID</span>
            </span>
          </div>
          <h3 class="job-card__title">Creative Lead</h3>
          <p class="job-card__desc">Define the visual language of high-performance architectural systems. Shape how our clients' brands communicate precision and authority.</p>
          <a href="/book-a-call" class="btn btn--ghost">Apply Now</a>
        </div>

        <div class="job-card">
          <div class="job-card__meta">
            <span class="job-card__dept job-card__dept--engineering">Engineering</span>
            <span class="job-card__tags">
              <span class="tag">REMOTE</span>
              <span class="tag">FULL-TIME</span>
            </span>
          </div>
          <h3 class="job-card__title">Full-Stack Engineer</h3>
          <p class="job-card__desc">Architect seamless bridges between complex backend logic and pixel-perfect UIs. Own features end-to-end across our most challenging builds.</p>
          <a href="/book-a-call" class="btn btn--ghost">Apply Now</a>
        </div>

      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="benefits">
    <div class="container">
      <h2 class="section-title">Designed for Mastery</h2>
      <div class="benefits__grid">
        <div class="benefit">
          <div class="benefit__icon">🌐</div>
          <h3 class="benefit__title">Remote-First</h3>
          <p class="benefit__desc">Work globally with seamless infrastructure and no location constraints. Your output matters, not your timezone.</p>
        </div>
        <div class="benefit">
          <div class="benefit__icon">⚡</div>
          <h3 class="benefit__title">High-Performance Stack</h3>
          <p class="benefit__desc">Advanced tools without legacy systems. We invest in resilient, modern infrastructure so you can do your best work.</p>
        </div>
        <div class="benefit">
          <div class="benefit__icon">🎓</div>
          <h3 class="benefit__title">Professional Mastery</h3>
          <p class="benefit__desc">Weekly workshops and annual stipends for continuous skill development. We grow because you grow.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="philosophy">
    <div class="container philosophy__inner">
      <blockquote class="philosophy__quote">
        "We treat code like physical steel — every line must serve structural purpose and every pixel must drive performance."
      </blockquote>
      <p class="philosophy__sub">We're seeking engineers and designers who ask both <em>why</em> and <em>how</em>.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-section__inner">
      <h2 class="cta-section__heading">Ready to architect the future?</h2>
      <p class="cta-section__desc">Don't see your role listed? We always want to hear from exceptional talent. Reach out with your portfolio and tell us what you'd build.</p>
      <a href="/book-a-call" class="btn btn--primary">Get in Touch</a>
    </div>
  </section>

</BaseLayout>

<style>
  .btn {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 0.9rem;
    transition: opacity 0.2s, transform 0.2s;
    border: 2px solid transparent;
  }
  .btn:hover { opacity: 0.85; transform: translateY(-1px); }
  .btn--primary { background: var(--color-accent); color: #fff; }
  .btn--ghost { border-color: var(--color-border); color: var(--color-text); }
  .btn--ghost:hover { border-color: var(--color-accent); }

  .careers-hero {
    padding: 6rem 0 4rem;
    border-bottom: 1px solid var(--color-border);
  }
  .careers-hero__heading {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1.5rem;
    max-width: 720px;
  }
  .careers-hero__desc {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 620px;
    line-height: 1.7;
  }

  .positions { padding: 5rem 0; }
  .section-title { font-size: 2rem; font-weight: 700; margin-bottom: 2.5rem; }

  .positions__list { display: flex; flex-direction: column; gap: 1.5rem; }
  .job-card {
    padding: 2rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: border-color 0.2s;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .job-card:hover { border-color: var(--color-accent); }
  .job-card__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .job-card__dept {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }
  .job-card__dept--engineering { background: rgba(37,99,235,0.2); color: #60a5fa; }
  .job-card__dept--design { background: rgba(139,92,246,0.2); color: #a78bfa; }
  .job-card__tags { display: flex; gap: 0.5rem; }
  .tag {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.15rem 0.5rem;
  }
  .job-card__title { font-size: 1.2rem; font-weight: 700; }
  .job-card__desc { color: var(--color-text-muted); line-height: 1.6; font-size: 0.9rem; }

  .benefits {
    padding: 5rem 0;
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .benefits__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.5rem;
  }
  .benefit {
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg);
    transition: border-color 0.2s;
  }
  .benefit:hover { border-color: var(--color-accent); }
  .benefit__icon { font-size: 1.75rem; margin-bottom: 1rem; }
  .benefit__title { font-size: 1rem; font-weight: 700; margin-bottom: 0.75rem; }
  .benefit__desc { color: var(--color-text-muted); font-size: 0.875rem; line-height: 1.6; }

  .philosophy {
    padding: 5rem 0;
    text-align: center;
  }
  .philosophy__inner { max-width: 680px; margin: 0 auto; }
  .philosophy__quote {
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.5;
    font-style: italic;
    margin-bottom: 1.5rem;
    opacity: 0.85;
  }
  .philosophy__sub {
    color: var(--color-text-muted);
    font-size: 1rem;
  }

  .cta-section {
    padding: 5rem 0;
    text-align: center;
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
  }
  .cta-section__heading { font-size: 2.25rem; font-weight: 800; margin-bottom: 1rem; }
  .cta-section__desc {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    margin-bottom: 2rem;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }
</style>
