---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Book a Call" description="Schedule a strategy session with Kaya Blue">
<main class="pt-20 pb-24 px-6 aura-glow">
<div class="max-w-7xl mx-auto">
<header class="text-center mb-20 max-w-4xl mx-auto">
<span class="font-mono text-[12px] uppercase tracking-widest text-accent mb-4 block">Schedule an appointment</span>
<h1 class="text-5xl md:text-7xl font-black text-white tracking-tighter leading-none mb-6">
Let's talk about your project
</h1>
<p class="text-lg md:text-xl text-text-muted max-w-2xl mx-auto leading-relaxed">
Engineering high-performance digital systems for organizations that demand technical prestige and uncompromising speed.
</p>
</header>
<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
<!-- Contact Form -->
<section class="lg:col-span-8 bg-surface-container rounded-xl p-8 border border-outline-variant/20 shadow-2xl">
<h3 class="text-xl font-bold text-white mb-6">Send Us a Message</h3>
<form id="contact-form" novalidate class="space-y-6">
<input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" />
<div>
<label for="name" class="block text-[12px] text-text-muted uppercase tracking-wide mb-2">Full Name <span class="text-accent">*</span></label>
<input type="text" id="name" name="name" required class="w-full bg-surface-container-highest border border-outline-variant/30 text-white rounded-lg px-4 py-3 focus:outline-none focus:border-accent transition-colors" placeholder="Your name" />
</div>
<div>
<label for="email" class="block text-[12px] text-text-muted uppercase tracking-wide mb-2">Email Address <span class="text-accent">*</span></label>
<input type="email" id="email" name="email" required class="w-full bg-surface-container-highest border border-outline-variant/30 text-white rounded-lg px-4 py-3 focus:outline-none focus:border-accent transition-colors" placeholder="you@company.com" />
</div>
<div>
<label for="phone" class="block text-[12px] text-text-muted uppercase tracking-wide mb-2">Phone <span class="text-text-muted">(optional)</span></label>
<input type="tel" id="phone" name="phone" class="w-full bg-surface-container-highest border border-outline-variant/30 text-white rounded-lg px-4 py-3 focus:outline-none focus:border-accent transition-colors" placeholder="+1 (555) 000-0000" />
</div>
<div>
<label for="preferredDate" class="block text-[12px] text-text-muted uppercase tracking-wide mb-2">Preferred Date <span class="text-text-muted">(optional)</span></label>
<input type="date" id="preferredDate" name="preferredDate" class="w-full bg-surface-container-highest border border-outline-variant/30 text-white rounded-lg px-4 py-3 focus:outline-none focus:border-accent transition-colors" />
</div>
<div>
<label for="message" class="block text-[12px] text-text-muted uppercase tracking-wide mb-2">Message <span class="text-accent">*</span></label>
<textarea id="message" name="message" required rows="5" class="w-full bg-surface-container-highest border border-outline-variant/30 text-white rounded-lg px-4 py-3 focus:outline-none focus:border-accent transition-colors resize-vertical" placeholder="Tell us about your project..."></textarea>
</div>
<button type="submit" class="w-full py-4 bg-accent text-primary font-black rounded-lg shadow-[0_0_20px_rgba(100,255,218,0.3)] active:scale-[0.98] transition-all hover:opacity-90 text-lg">
Send Message
</button>
<p id="form-status" aria-live="polite" class="text-sm min-h-[1.4em]"></p>
</form>
</section>
<!-- Contact Details -->
<aside class="lg:col-span-4 space-y-8">
<div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/10">
<h3 class="font-mono text-[10px] uppercase tracking-widest text-accent mb-6">Contact Channels</h3>
<div class="space-y-6">
<div class="flex items-start gap-4">
<div class="bg-surface-container-highest p-2 rounded-lg">
<span class="material-symbols-outlined text-accent">mail</span>
</div>
<div>
<p class="text-[12px] text-text-muted uppercase tracking-wide">Email</p>
<a class="text-lg font-bold text-white hover:text-accent transition-colors" href="mailto:hello@kayablue.com">hello@kayablue.com</a>
</div>
</div>
<div class="flex items-start gap-4">
<div class="bg-surface-container-highest p-2 rounded-lg">
<span class="material-symbols-outlined text-accent">call</span>
</div>
<div>
<p class="text-[12px] text-text-muted uppercase tracking-wide">Studio Line</p>
<p class="text-lg font-bold text-white">+1 (555) 000-1234</p>
</div>
</div>
<div class="flex items-start gap-4">
<div class="bg-surface-container-highest p-2 rounded-lg">
<span class="material-symbols-outlined text-accent">location_on</span>
</div>
<div>
<p class="text-[12px] text-text-muted uppercase tracking-wide">Address</p>
<p class="text-lg font-bold text-white">128 Matrix Plaza, Suite 400<br>San Francisco, CA 94103</p>
</div>
</div>
</div>
</div>
<div class="relative h-48 rounded-xl overflow-hidden bg-surface-container-highest">
<img class="w-full h-full object-cover opacity-40 grayscale contrast-125" alt="Stylized dark map of San Francisco area" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD6QeepSyh0ea8cVHZ_mlguJjQOp9Qf2Mddk3am_3qWUEPAVFboIZg8YxnlHrCvQGpIH7xAq5O0anbDT52IRWG_6gNMEN032t_hFO-1d0iVp-rY8E2slvggQYjRYucyMZFma9R7Yx5k5U3Poiujok_1ZSNJnjYyBP0JZpPUTYylglONGBg5PDHWvhGp6I3sBC2eyfAUQBxA13efJ5t5Vdil2ZlIASfeO9jFNuiTk0uwd9LnDW6sm4pXLK4gICSRuwT6-ns7yVyNXhw" />
<div class="absolute inset-0 bg-gradient-to-t from-surface-container-low to-transparent"></div>
<div class="absolute bottom-4 left-4">
<span class="font-mono text-[10px] text-accent">HQ: LAT 37.77 / LONG -122.41</span>
</div>
</div>
</aside>
</div>
<!-- Common Inquiries -->
<section class="mt-32">
<div class="flex items-end justify-between mb-12 border-b border-outline-variant/30 pb-6">
<div>
<h2 class="text-3xl font-black text-white tracking-tight">Common Inquiries</h2>
<p class="text-text-muted mt-2">Handling objections before we even start.</p>
</div>
<span class="material-symbols-outlined text-accent text-4xl">info</span>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
<div class="bg-surface-container p-8 rounded-xl border border-outline-variant/10 hover:border-accent/50 transition-all group">
<div class="mb-6 flex justify-between items-start">
<span class="font-mono text-[12px] text-accent">01</span>
<span class="material-symbols-outlined text-text-muted group-hover:text-accent transition-colors">schedule</span>
</div>
<h4 class="text-xl font-bold text-white mb-3">Project Timelines</h4>
<p class="text-text-muted leading-relaxed">Typical architecture phases last 6-12 weeks depending on complexity. We prioritize milestones over hours.</p>
</div>
<div class="bg-surface-container p-8 rounded-xl border border-outline-variant/10 hover:border-accent/50 transition-all group">
<div class="mb-6 flex justify-between items-start">
<span class="font-mono text-[12px] text-accent">02</span>
<span class="material-symbols-outlined text-text-muted group-hover:text-accent transition-colors">payments</span>
</div>
<h4 class="text-xl font-bold text-white mb-3">Investment Model</h4>
<p class="text-text-muted leading-relaxed">We work on a value-based fixed pricing or monthly technical retainer. No hidden overheads or surprise invoices.</p>
</div>
<div class="bg-surface-container p-8 rounded-xl border border-outline-variant/10 hover:border-accent/50 transition-all group">
<div class="mb-6 flex justify-between items-start">
<span class="font-mono text-[12px] text-accent">03</span>
<span class="material-symbols-outlined text-text-muted group-hover:text-accent transition-colors">terminal</span>
</div>
<h4 class="text-xl font-bold text-white mb-3">Tech Stack</h4>
<p class="text-text-muted leading-relaxed">Agnostic but performance-obsessed. Specialized in Next.js, Astro, and scalable cloud infrastructures.</p>
</div>
</div>
</section>
</div>
</main>
<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));
    status.textContent = 'Sending...';
    status.className = 'text-sm min-h-[1.4em]';
    try {
      const res = await fetch('https://api.kayablue.nl/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json();
      if (json.success) {
        status.textContent = "Thanks! We'll be in touch shortly.";
        status.className = 'text-sm min-h-[1.4em] text-green-400';
        form.reset();
      } else {
        status.textContent = json.error || 'Something went wrong. Please try again.';
        status.className = 'text-sm min-h-[1.4em] text-red-400';
      }
    } catch {
      status.textContent = 'Network error. Please try again.';
      status.className = 'text-sm min-h-[1.4em] text-red-400';
    }
  });
</script>
</BaseLayout>
