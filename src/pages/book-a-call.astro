---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Book a Call" description="Schedule a strategy session with Kayablue">

  <!-- Hero -->
  <section class="bac-hero">
    <div class="container">
      <p class="bac-hero__label">Schedule an appointment</p>
      <h1 class="bac-hero__heading">Let's talk about your project</h1>
      <p class="bac-hero__desc">We engineer high-performance digital systems for demanding organisations. Tell us about your goals and we'll map out the path forward.</p>
    </div>
  </section>

  <!-- Main content: form + contact info -->
  <section class="bac-main">
    <div class="container bac-main__inner">

      <!-- Contact Form -->
      <div class="form-panel">
        <h2 class="form-panel__title">Send us a message</h2>
        <form id="contact-form" class="contact-form" novalidate>
          <!-- Honeypot -->
          <input type="text" name="website" tabindex="-1" autocomplete="off" style="display:none;" />

          <div class="form-group">
            <label for="name" class="form-label">Full Name <span class="req">*</span></label>
            <input type="text" id="name" name="name" required class="form-input" placeholder="Your name" />
          </div>

          <div class="form-group">
            <label for="email" class="form-label">Email Address <span class="req">*</span></label>
            <input type="email" id="email" name="email" required class="form-input" placeholder="you@company.com" />
          </div>

          <div class="form-group">
            <label for="phone" class="form-label">Phone <span class="opt">(optional)</span></label>
            <input type="tel" id="phone" name="phone" class="form-input" placeholder="+1 (555) 000-0000" />
          </div>

          <div class="form-group">
            <label for="preferredDate" class="form-label">Preferred Date <span class="opt">(optional)</span></label>
            <input type="date" id="preferredDate" name="preferredDate" class="form-input" />
          </div>

          <div class="form-group">
            <label for="message" class="form-label">Message <span class="req">*</span></label>
            <textarea id="message" name="message" required class="form-input form-textarea" rows="5" placeholder="Tell us about your project..."></textarea>
          </div>

          <button type="submit" class="btn btn--primary btn--full">Send Message</button>
          <p id="form-status" aria-live="polite" class="form-status"></p>
        </form>
      </div>

      <!-- Contact Info + FAQ -->
      <div class="info-panel">
        <div class="contact-channels">
          <h2 class="info-panel__title">Contact Channels</h2>
          <div class="channel">
            <span class="channel__label">Email</span>
            <a href="mailto:hello@kayablue.com" class="channel__value">hello@kayablue.com</a>
          </div>
          <div class="channel">
            <span class="channel__label">Phone</span>
            <a href="tel:+15550001234" class="channel__value">+1 (555) 000-1234</a>
          </div>
          <div class="channel">
            <span class="channel__label">Studio</span>
            <span class="channel__value">128 Matrix Plaza, Suite 400<br />San Francisco, CA 94103</span>
          </div>
        </div>

        <div class="faq">
          <h2 class="info-panel__title">Common Questions</h2>

          <div class="faq-item">
            <h3 class="faq-item__q">How long does a project take?</h3>
            <p class="faq-item__a">Most projects move through 6–12 week architecture phases depending on scope and complexity.</p>
          </div>

          <div class="faq-item">
            <h3 class="faq-item__q">How is pricing structured?</h3>
            <p class="faq-item__a">We offer value-based fixed pricing for defined projects and monthly retainers for ongoing partnerships.</p>
          </div>

          <div class="faq-item">
            <h3 class="faq-item__q">What tech stack do you use?</h3>
            <p class="faq-item__a">We specialise in Next.js, Astro, and scalable cloud infrastructure — chosen for your specific performance requirements.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));
    status.textContent = 'Sending...';
    status.className = 'form-status';
    try {
      const res = await fetch('https://api.kayablue.nl/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json();
      if (json.success) {
        status.textContent = "Thanks! We'll be in touch shortly.";
        status.className = 'form-status form-status--success';
        form.reset();
      } else {
        status.textContent = json.error || 'Something went wrong. Please try again.';
        status.className = 'form-status form-status--error';
      }
    } catch {
      status.textContent = 'Network error. Please try again.';
      status.className = 'form-status form-status--error';
    }
  });
</script>

<style>
  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 0.95rem;
    transition: opacity 0.2s, transform 0.2s;
    cursor: pointer;
    border: none;
  }
  .btn:hover { opacity: 0.85; transform: translateY(-1px); }
  .btn--primary { background: var(--color-accent); color: #fff; }
  .btn--full { width: 100%; text-align: center; }

  .bac-hero {
    padding: 6rem 0 4rem;
    border-bottom: 1px solid var(--color-border);
  }
  .bac-hero__label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }
  .bac-hero__heading {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }
  .bac-hero__desc {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 580px;
    line-height: 1.7;
  }

  .bac-main { padding: 5rem 0; }
  .bac-main__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Form */
  .form-panel__title, .info-panel__title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.75rem;
  }
  .contact-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .form-label { font-size: 0.875rem; font-weight: 600; }
  .req { color: var(--color-accent); }
  .opt { color: var(--color-text-muted); font-weight: 400; }
  .form-input {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-text);
    font-family: var(--font-family);
    font-size: 0.95rem;
    padding: 0.7rem 1rem;
    width: 100%;
    transition: border-color 0.2s;
    outline: none;
  }
  .form-input:focus { border-color: var(--color-accent); }
  .form-textarea { resize: vertical; min-height: 120px; }
  .form-status {
    font-size: 0.9rem;
    min-height: 1.4em;
    margin-top: 0.25rem;
  }
  .form-status--success { color: #34d399; }
  .form-status--error { color: #f87171; }

  /* Info panel */
  .contact-channels { margin-bottom: 3rem; }
  .channel {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .channel:last-child { border-bottom: none; }
  .channel__label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-muted); }
  .channel__value { font-size: 1rem; color: var(--color-text); line-height: 1.5; }
  a.channel__value { color: var(--color-accent); }
  a.channel__value:hover { text-decoration: underline; }

  .faq { display: flex; flex-direction: column; gap: 1.5rem; }
  .faq-item__q { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.4rem; }
  .faq-item__a { font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.6; }

  @media (max-width: 800px) {
    .bac-main__inner { grid-template-columns: 1fr; gap: 3rem; }
  }
</style>
