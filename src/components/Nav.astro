---
---
<header class="sticky top-0 z-50 w-full border-b border-slate-200 dark:border-slate-800 bg-background-light/80 dark:bg-background-dark/80 backdrop-blur-md px-6 lg:px-20 py-4">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <div class="flex items-center gap-2">
      <a href="/" class="flex items-center gap-2">
        <div class="text-accent">
          <span class="material-symbols-outlined text-3xl">terminal</span>
        </div>
        <h2 class="text-xl font-bold tracking-tight text-slate-900 dark:text-white">Kaya <span class="text-accent">Blue</span></h2>
      </a>
    </div>
    <nav class="hidden md:flex items-center gap-10">
      <a class="text-sm font-medium hover:text-accent transition-colors" href="/services">Services</a>
      <a class="text-sm font-medium hover:text-accent transition-colors" href="/industries">Industries</a>
      <a class="text-sm font-medium hover:text-accent transition-colors" href="/our-work">Portfolio</a>
      <a class="text-sm font-medium hover:text-accent transition-colors" href="/about">About</a>
      <a class="text-sm font-medium hover:text-accent transition-colors" href="/careers">Careers</a>
    </nav>
    <div class="hidden md:block">
      <a href="/book-a-call" class="bg-accent text-primary px-6 py-2 rounded font-bold text-sm hover:opacity-90 transition-all accent-glow">
        Book a Call
      </a>
    </div>
    <button id="menu-btn" class="md:hidden flex items-center justify-center text-slate-900 dark:text-white focus:outline-none" aria-label="Toggle menu">
      <span class="material-symbols-outlined text-3xl">menu</span>
    </button>
  </div>
  <div id="mobile-menu" class="hidden flex-col md:hidden gap-4 pt-4 pb-2 border-t border-slate-200 dark:border-slate-800 mt-4">
    <a class="text-sm font-medium hover:text-accent transition-colors px-2 py-1" href="/services">Services</a>
    <a class="text-sm font-medium hover:text-accent transition-colors px-2 py-1" href="/industries">Industries</a>
    <a class="text-sm font-medium hover:text-accent transition-colors px-2 py-1" href="/our-work">Portfolio</a>
    <a class="text-sm font-medium hover:text-accent transition-colors px-2 py-1" href="/about">About</a>
    <a class="text-sm font-medium hover:text-accent transition-colors px-2 py-1" href="/careers">Careers</a>
    <a href="/book-a-call" class="bg-accent text-primary px-6 py-2 rounded font-bold text-sm text-center mt-2 hover:opacity-90 transition-all accent-glow">
      Book a Call
    </a>
  </div>
</header>
<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
  });
</script>
